# ─────────────────────────────────────────────────
# Ticket Tailor Webhook Secret
# Found in: Ticket Tailor Dashboard → Settings → Webhooks → Secret
# ─────────────────────────────────────────────────
TICKET_TAILOR_WEBHOOK_SECRET=whsec_replace_with_your_secret

# ─────────────────────────────────────────────────
# Supabase Configuration
# Found in: Supabase Project Settings → API
# ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────
# SendGrid Email Settings
# Create API key at: https://app.sendgrid.com/settings/api_keys
# ─────────────────────────────────────────────────
SENDGRID_API_KEY=SG.replace_with_your_sendgrid_key
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Sunbol Onsa Festival Team

# ─────────────────────────────────────────────────
# Admin Setup
# ─────────────────────────────────────────────────
ADMIN_EMAIL=sunbolonsa@gmail.com
ADMIN_PASSWORD=123123

# ─────────────────────────────────────────────────
# Server Settings
# ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
